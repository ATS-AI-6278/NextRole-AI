# Telegram
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_WEBHOOK_SECRET=your_secret_here
TELEGRAM_BASE_URL=https://your-public-url.com

# Gmail OAuth
GMAIL_OAUTH_CLIENT_ID=your_client_id
GMAIL_OAUTH_CLIENT_SECRET=your_client_secret
GMAIL_OAUTH_REDIRECT_URL=http://localhost:8000/gmail/oauth/callback

# Multi-tenant data
DATABASE_URL=sqlite:///./nextrole.db
CHROMA_PERSIST_DIR=./chroma_data

# Privacy/Redaction
ENCRYPTION_KEY=your_encryption_key_32_bytes

# Server
ENVIRONMENT=devd

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
